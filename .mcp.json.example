{
  "mcpServers": {
    "n8n-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "http://<your-n8n-host>:5678/mcp-server/http",
        "--allow-http",
        "--header",
        "Authorization:Bearer ${N8N_MCP_TOKEN}"
      ],
      "env": {
        "N8N_MCP_TOKEN": "REPLACE_WITH_N8N_MCP_TOKEN"
      }
    }
  }
}
