# --- LLM / search providers ---
SERP_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Enrichment (free tiers)
HUNTER_API_KEY=

# Scraping layer — optional. Uncomment + fill only if ingest hits JS-render /
# anti-bot walls. Drop-in behind the n8n HTTP node. (Discovery=serp.dev,
# deep-research=Claude Code headless; this would cover high-volume ingest only.)
# SCRAPINGBEE_API_KEY=

# --- pipeline config ---
# comma-separated operating regions; leads outside these are hard-gated
TARGET_REGIONS=us-west,uk
# only leads at/above this score advance to deep-research + draft
MIN_FIT_SCORE=70
# demo safety: where approved sends go (NEVER real third parties in demo)
SANDBOX_OUTREACH_EMAIL=

# --- postgres ---
POSTGRES_USER=groundbreaker
POSTGRES_PASSWORD=change_me
POSTGRES_DB=groundbreaker

# --- n8n ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_HOST=localhost
N8N_PORT=5678
GENERIC_TIMEZONE=America/Los_Angeles
